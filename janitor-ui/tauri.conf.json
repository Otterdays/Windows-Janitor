{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Janitor",
  "version": "0.1.0",
  "identifier": "com.janitor.app",
  "build": {
    "frontendDist": "dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Janitor — Safe PC Cleaner",
        "width": 1100,
        "height": 750,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
